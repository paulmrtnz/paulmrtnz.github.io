{
  "name": "paulmrtnz-github-io",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i css/input.css -o css/styles.css --minify",
    "watch:css": "tailwindcss -i css/input.css -o css/styles.css --watch=always",
    "dev": "trap 'kill 0' EXIT; npm run watch:css & bundle exec jekyll serve"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0"
  }
}
